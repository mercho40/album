# Local dev: usar la URL del Neon develop branch.
# Producción (Fly.io): setear con `fly secrets set DATABASE_URL=...` (no commitear).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Generar con: openssl rand -base64 32
# Debe coincidir con el del web app.
BETTER_AUTH_SECRET=

# Local: http://localhost:3000
# Producción: https://album-back.fly.dev
BETTER_AUTH_URL=http://localhost:3000

# Origin del front. Local: http://localhost:3001
# Producción: https://<dominio Vercel>
WEB_URL=http://localhost:3001

# OAuth providers (opcionales)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
