# Local: usar la URL del Neon develop branch.
# Producción: se inyecta vía haloy (secret del deploy, ver haloy.yaml + ci.yml).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Generar con: openssl rand -base64 32
# Debe coincidir con el del web app.
BETTER_AUTH_SECRET=

# Local: http://localhost:3000
# Producción: dominio público del back (ej. https://api.album.tudominio.com)
BETTER_AUTH_URL=http://localhost:3000

# Origin del front. Local: http://localhost:3001
# Producción: dominio del web (ej. https://album.mersich.net)
WEB_URL=http://localhost:3001

# Parent domain para que las cookies de auth crucen subdominios (front y back en sub-domains).
# Local: dejar vacío. Producción: ej. .mersich.net (con punto inicial).
COOKIE_DOMAIN=

# OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel Blob: token del store para la subida de fotos de perfil (avatares).
# Local: crear un store en el dashboard de Vercel y pegar el token acá.
# Producción: se inyecta vía haloy (secret del deploy, ver haloy.yaml + ci.yml).
BLOB_READ_WRITE_TOKEN=
